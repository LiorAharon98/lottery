{
  "cli": {
    "version": ">= 3.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m1-medium"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",

      "ios": {
        "resourceClass": "m1-medium"
      }
    },
    "production": {
      "channel": "production",

      "ios": {
        "resourceClass": "m1-medium"
      },
      "android": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-console-api.json"
      }
    }
  }
}
